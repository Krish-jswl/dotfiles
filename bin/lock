#!/usr/bin/env bash
set -euo pipefail

# Everforest Dark (Medium) 🌲
BG="2d353bff"
FG="d3c6aaff"        # warm soft foreground
RING="475258ff"      # subtle ring
ACCENT="83c092ff"    # green accent
RED="e67e80ff"
GREEN="a7c080ff"
YELLOW="dbbc7fff"
BLACK="343f44ff"
BLANK="00000000"

i3lock \
  --color="${BG}" \
  \
  --insidever-color="${BLANK}" \
  --ringver-color="${ACCENT}" \
  \
  --insidewrong-color="${BLANK}" \
  --ringwrong-color="${RED}" \
  \
  --inside-color="${BLANK}" \
  --ring-color="${RING}" \
  --line-color="${BLANK}" \
  --separator-color="${BLACK}" \
  \
  --verif-color="${ACCENT}" \
  --wrong-color="${RED}" \
  --time-color="${FG}" \
  --date-color="${FG}" \
  --layout-color="${FG}" \
  \
  --keyhl-color="${GREEN}" \
  --bshl-color="${RED}" \
  \
  --clock \
  --indicator \
  --time-str="%H:%M" \
  --date-str="%A, %d %b" \
  \
  --radius=110 \
  --ring-width=6 \
  \
  --pass-media-keys \
  --pass-screen-keys \
  --pass-power-keys
